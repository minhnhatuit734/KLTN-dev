FROM node:20-alpine
WORKDIR /app
COPY package*.json ./

# Thêm DNS fallback ngay trong RUN
RUN npm config set registry https://registry.npmjs.org/ && \
    npm install --legacy-peer-deps --prefer-offline || \
    npm install --legacy-peer-deps

COPY . .
RUN npm run build
EXPOSE 4000
CMD ["node", "dist/main.js"]